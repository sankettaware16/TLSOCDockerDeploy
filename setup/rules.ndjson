{"id":"02c535a8-665a-4b14-8ac4-1f47935af004","updated_at":"2026-05-12T06:17:21.961Z","updated_by":"elastic","created_at":"2026-05-12T06:17:21.961Z","created_by":"elastic","name":"SSH Successful Login","tags":["Identity","Host"],"interval":"1s","enabled":true,"revision":0,"description":"Detects a successful SSH authentication event processed by the service. This indicates a user has successfully gained shell access to a host","risk_score":21,"severity":"low","note":"### Triage Steps\n\n1. **Verify User Identity:**\n   - Confirm if user `{{parsed_data.user}}` is authorized to access host `{{service}}`.\n   - If the user is `root`, treat with higher priority.\n\n2. **Analyze Source IP:**\n   - Check `{{parsed_data.src_ip}}` against internal asset lists.\n   - If the IP is external (public), check Geo-location and reputation (VirusTotal/AbuseIPDB).\n\n3. **Contextual Analysis:**\n   - Is this login occurring during standard business hours?\n   - Check for multiple failed login attempts immediately preceding this success (Brute Force followed by Success).","license":"","output_index":"","meta":{"from":"5m","kibana_siem_app_url":"https://10.130.171.246:5601/s/tlsoc/app/security"},"investigation_fields":{"field_names":["source.ip","user.name"]},"author":[],"false_positives":["Scheduled administrative logins ","Automated configuration management tools (e.g., Ansible) connecting via SSH"],"from":"now-301s","rule_id":"a075b408-c826-401f-99d7-64c2e6f5f1bb","max_signals":100,"risk_score_mapping":[],"severity_mapping":[],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0001","name":"Initial Access","reference":"https://attack.mitre.org/tactics/TA0001"},"technique":[{"id":"T1078","name":"Valid Accounts","reference":"https://attack.mitre.org/techniques/T1078","subtechnique":[{"id":"T1078.003","name":"Local Accounts","reference":"https://attack.mitre.org/techniques/T1078/003"}]}]}],"to":"now","references":[],"version":1,"exceptions_list":[],"immutable":false,"rule_source":{"